---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="About — Frank Young"
  description="Frank Young's professional background — Senior Software Engineer specializing in high-performance computing and AI acceleration."
>
  <Nav />

  <main class="container">
    <!-- Header -->
    <section class="page-header">
      <h1>Frank Young <span class="zh">杨行</span></h1>
      <p class="subtitle">Senior Software Engineer · High-Performance Computing</p>
      <div class="contact-row">
        <a href="mailto:2679frank@gmail.com">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          2679frank@gmail.com
        </a>
        <a href="https://github.com/frank2679" target="_blank" rel="noopener noreferrer">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          github.com/frank2679
        </a>
        <span>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.38 2 2 0 0 1 3.6 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.56a16 16 0 0 0 6 6l.85-.87a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.73 16z"/></svg>
          (+86) 131-6207-0162
        </span>
      </div>
    </section>

    <!-- Summary -->
    <section class="resume-section">
      <h2 class="section-title">Summary</h2>
      <p class="summary-text">
        Senior software engineer with 8+ years of experience building high-performance computation infrastructure
        for heterogeneous platforms (CPU/GPU/DSP/NPU). Deep expertise in operator acceleration libraries
        (BLAS, DNN, FFT), GEMM optimization, and AI model deployment. 3 years of engineering leadership
        experience managing teams of ~5 people. 5 AI-domain patents and 2 IEEE publications.
      </p>
      <p class="summary-text">
        Triathlon enthusiast — long-distance running, cycling, and swimming keep the mind sharp.
      </p>
    </section>

    <!-- Experience -->
    <section class="resume-section">
      <h2 class="section-title">Experience</h2>

      <div class="timeline">
        <div class="timeline-item">
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <div class="job-header">
              <div>
                <h3>Senior Software Engineer</h3>
                <span class="company">Alibaba DAMO Academy <span class="zh">阿里达摩院</span></span>
              </div>
              <span class="period">2024.12 – Present</span>
            </div>
            <ul class="job-duties">
              <li>GEMM-like operator development for next-generation AI inference chips</li>
              <li>Porting NVIDIA CUTLASS framework and CuTe layout algebra to new chip architecture</li>
              <li>Implementing generalized GEMM operators with handwritten assembly optimization</li>
            </ul>
            <div class="job-tags">
              <span class="tag">C++</span>
              <span class="tag">CUTLASS</span>
              <span class="tag">GEMM</span>
              <span class="tag">Assembly</span>
            </div>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <div class="job-header">
              <div>
                <h3>Senior Software Engineer / Team Lead</h3>
                <span class="company">Biren Technology <span class="zh">壁仞科技</span></span>
              </div>
              <span class="period">2021.01 – 2024.11</span>
            </div>
            <ul class="job-duties">
              <li>Built BLAS acceleration library from scratch on proprietary GPGPU platform — testing, operator development, kernel selection, benchmarking, CI/CD, and documentation</li>
              <li>Optimized performance across major LLM workloads (Qwen, Llama2, GPT series), reaching A100-level throughput on first-generation chips</li>
              <li>Implemented advanced optimization strategies: warp-specialized programming, fused bias/gradient accumulation, BF16 accumulation</li>
              <li>Led a team of ~5 engineers; owned technical roadmap and delivery</li>
              <li>Filed 3 patents in AI acceleration</li>
            </ul>
            <div class="job-tags">
              <span class="tag">C++</span>
              <span class="tag">CUDA</span>
              <span class="tag">BLAS</span>
              <span class="tag">LLM</span>
              <span class="tag">Team Lead</span>
            </div>
          </div>
        </div>

        <div class="timeline-item">
          <div class="timeline-marker"></div>
          <div class="timeline-content">
            <div class="job-header">
              <div>
                <h3>Software Engineer</h3>
                <span class="company">Hikvision <span class="zh">海康威视</span></span>
              </div>
              <span class="period">2017.07 – 2020.12</span>
            </div>
            <ul class="job-duties">
              <li>Developed high-performance CNN library for heterogeneous AI inference platforms</li>
              <li>Optimized convolution and matrix operations on CPU/DSP/NPU</li>
              <li>Full project ownership from business requirements to production deployment</li>
            </ul>
            <div class="job-tags">
              <span class="tag">C++</span>
              <span class="tag">CNN</span>
              <span class="tag">DSP</span>
              <span class="tag">NPU</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Education -->
    <section class="resume-section">
      <h2 class="section-title">Education</h2>

      <div class="edu-grid">
        <div class="edu-card">
          <div class="edu-header">
            <div>
              <h3>M.S. Telecommunications</h3>
              <span class="school">National Taiwan University <span class="zh">台湾大学</span></span>
            </div>
            <span class="period">2014.09 – 2017.01</span>
          </div>
          <p class="edu-detail">Institute of Telecommunications — Published 2 IEEE papers on 802.11ax WiFi protocol</p>
        </div>

        <div class="edu-card">
          <div class="edu-header">
            <div>
              <h3>B.E. Communication Engineering</h3>
              <span class="school">Chongqing University <span class="zh">重庆大学</span></span>
            </div>
            <span class="period">2010.09 – 2014.06</span>
          </div>
          <p class="edu-detail">Top 5% of program · Outstanding Graduate · Multiple merit scholarships</p>
        </div>
      </div>
    </section>

    <!-- Publications -->
    <section class="resume-section">
      <h2 class="section-title">Publications</h2>
      <div class="pub-list">
        <div class="pub-item">
          <span class="pub-venue">IEEE Access 2018</span>
          <p class="pub-title">Energy Saving in IEEE 802.11ax</p>
          <p class="pub-authors">Yang, Hang; Deng, Der-Jiunn; Chen, Kwang-Cheng · Vol. 6, pp. 47546–47556</p>
        </div>
        <div class="pub-item">
          <span class="pub-venue">IEEE GLOBECOM 2017</span>
          <p class="pub-title">Performance Analysis of IEEE 802.11ax UL OFDMA-based Random Access Mechanism</p>
          <p class="pub-authors">Yang, Hang; Deng, Der-Jiunn; Chen, Kwang-Cheng · pp. 1–6</p>
        </div>
      </div>
    </section>

    <!-- Patents & IP -->
    <section class="resume-section">
      <h2 class="section-title">Patents & IP</h2>
      <div class="ip-grid">
        <div class="ip-card">
          <span class="ip-num">5</span>
          <span class="ip-label">AI Patents</span>
        </div>
        <div class="ip-card">
          <span class="ip-num">1</span>
          <span class="ip-label">Communications Patent</span>
        </div>
        <div class="ip-card">
          <span class="ip-num">1</span>
          <span class="ip-label">Software Copyright</span>
        </div>
      </div>
    </section>

    <!-- Skills -->
    <section class="resume-section">
      <h2 class="section-title">Technical Skills</h2>
      <div class="skills-table">
        <div class="skill-row">
          <span class="skill-cat">Languages</span>
          <span class="skill-vals">C++, C, Python, CUDA, Assembly</span>
        </div>
        <div class="skill-row">
          <span class="skill-cat">Domains</span>
          <span class="skill-vals">BLAS, GEMM, CUTLASS, CNN, DNN, LLM inference</span>
        </div>
        <div class="skill-row">
          <span class="skill-cat">Tools</span>
          <span class="skill-vals">CMake, Git, Jenkins, JIRA, Verdi/SimVision</span>
        </div>
        <div class="skill-row">
          <span class="skill-cat">Platforms</span>
          <span class="skill-vals">GPU, DSP, NPU, heterogeneous HPC</span>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>

<style>
  main {
    padding-top: 3rem;
    padding-bottom: 4rem;
  }

  .page-header {
    margin-bottom: 3rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--border);
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.4rem;
  }

  .zh {
    color: var(--text-muted);
    font-size: 0.7em;
    font-weight: 400;
    margin-left: 0.5rem;
  }

  .subtitle {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.95rem;
    margin-bottom: 1.25rem;
  }

  .contact-row {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
    align-items: center;
  }

  .contact-row a,
  .contact-row span {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--text-secondary);
    font-size: 0.875rem;
    transition: color 0.2s;
  }

  .contact-row a:hover {
    color: var(--accent);
  }

  /* Sections */
  .resume-section {
    margin-bottom: 3.5rem;
  }

  .section-title {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    font-family: var(--font-mono);
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .section-title::after {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  /* Summary */
  .summary-text {
    color: var(--text-secondary);
    line-height: 1.8;
    max-width: 720px;
  }

  .summary-text + .summary-text {
    margin-top: 0.75rem;
  }

  /* Timeline */
  .timeline {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 1px 1fr;
    gap: 0 1.5rem;
    position: relative;
  }

  .timeline-marker {
    width: 10px;
    height: 10px;
    background: var(--accent);
    border-radius: 50%;
    position: absolute;
    left: -4px;
    top: 6px;
    box-shadow: 0 0 0 3px var(--accent)22;
  }

  .timeline-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: -2.5rem;
    width: 1px;
    background: var(--border);
  }

  .timeline-item:last-child::before {
    display: none;
  }

  .timeline-content {
    padding-left: 1.5rem;
  }

  .job-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .job-header h3 {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 0.2rem;
  }

  .company {
    color: var(--text-secondary);
    font-size: 0.875rem;
  }

  .period {
    color: var(--text-muted);
    font-size: 0.8rem;
    font-family: var(--font-mono);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .job-duties {
    list-style: none;
    padding: 0;
    margin: 0 0 0.75rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .job-duties li {
    color: var(--text-secondary);
    font-size: 0.9rem;
    padding-left: 1rem;
    position: relative;
    line-height: 1.6;
  }

  .job-duties li::before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--accent);
    font-size: 0.75rem;
    top: 0.2em;
  }

  .job-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  /* Education */
  .edu-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1rem;
  }

  .edu-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.5rem;
  }

  .edu-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 0.6rem;
    flex-wrap: wrap;
  }

  .edu-header h3 {
    font-size: 0.95rem;
    font-weight: 600;
    margin-bottom: 0.2rem;
  }

  .school {
    color: var(--text-secondary);
    font-size: 0.85rem;
  }

  .edu-detail {
    color: var(--text-muted);
    font-size: 0.85rem;
    margin: 0;
  }

  /* Publications */
  .pub-list {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .pub-item {
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
  }

  .pub-venue {
    display: inline-block;
    font-size: 0.75rem;
    font-family: var(--font-mono);
    color: var(--accent);
    background: var(--accent-dim);
    padding: 0.15em 0.5em;
    border-radius: 4px;
    margin-bottom: 0.35rem;
  }

  .pub-title {
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 0.2rem;
    color: var(--text-primary);
  }

  .pub-authors {
    color: var(--text-muted);
    font-size: 0.82rem;
    margin: 0;
  }

  /* IP */
  .ip-grid {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .ip-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 1.25rem 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.25rem;
    min-width: 140px;
  }

  .ip-num {
    font-size: 2rem;
    font-weight: 700;
    color: var(--accent);
    line-height: 1;
  }

  .ip-label {
    color: var(--text-secondary);
    font-size: 0.8rem;
    text-align: center;
  }

  /* Skills table */
  .skills-table {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .skill-row {
    display: grid;
    grid-template-columns: 140px 1fr;
    gap: 1rem;
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid var(--border);
    align-items: center;
  }

  .skill-row:last-child {
    border-bottom: none;
  }

  .skill-cat {
    color: var(--accent);
    font-size: 0.8rem;
    font-family: var(--font-mono);
    font-weight: 500;
  }

  .skill-vals {
    color: var(--text-secondary);
    font-size: 0.875rem;
  }

  @media (max-width: 640px) {
    .skill-row {
      grid-template-columns: 1fr;
      gap: 0.3rem;
    }

    .job-header {
      flex-direction: column;
      gap: 0.25rem;
    }
  }
</style>

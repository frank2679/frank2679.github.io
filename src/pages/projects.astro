---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = [
  {
    title: 'CUTLASS Architecture Port',
    period: '2025.07 – Present',
    description:
      'Porting NVIDIA\'s CUTLASS framework and CuTe layout algebra to a new chip architecture. Implemented generalized GEMM operators using CUTLASS programming patterns with handwritten assembly for ultimate performance.',
    tags: ['C++', 'CUTLASS', 'GEMM', 'Assembly', 'GPU Architecture'],
    highlights: [
      'Studied CuTe layout algebra and CUTLASS programming model in depth',
      'Designed architecture-specific kernel variants for new chip ISA',
      'Achieved target utilization on Vcore/Tcore platforms for critical shapes',
      '2 patents filed for optimization techniques',
    ],
  },
  {
    title: 'BLAS Library — Production-Grade Acceleration',
    period: '2023.06 – 2024.11',
    description:
      'Built a full BLAS acceleration library from scratch on a proprietary GPGPU platform. The library powers LLM inference at A100-equivalent throughput, covering GEMM, batched GEMM, and strided variants.',
    tags: ['C++', 'CUDA', 'BLAS', 'GEMM', 'LLM', 'Performance'],
    highlights: [
      'End-to-end ownership: kernel development, testing harness, kernel selection, benchmarking, CI/CD, docs',
      'Optimized for Qwen, Llama2, GPT-series model shapes — matched A100 on first-gen chip',
      'Implemented warp-specialized programming, fused bias, fused grad accumulation, BF16 accumulation',
      '3 patents filed',
    ],
  },
  {
    title: 'Ultimate GEMM Optimization',
    period: '2021.09 – 2021.10 · 2025.06 – 2025.08',
    description:
      'Push-to-limits GEMM implementation using handwritten assembly and Verdi waveform analysis. Achieved full chip utilization for specific matrix shapes on both Vcore and Tcore architectures.',
    tags: ['Assembly', 'GEMM', 'Performance', 'Waveform Analysis'],
    highlights: [
      'Handwritten assembly for inner loop to eliminate compiler overhead',
      'Used Verdi/SimVision for cycle-accurate waveform analysis and pipeline optimization',
      'Full chip utilization achieved on target shapes',
      '2 patents filed',
    ],
  },
  {
    title: 'DNN Framework Development',
    period: '2022.03 – 2023.06',
    description:
      'Developed a deep learning framework with precision verification, inspired by PyTorch\'s design. Features a self-defined operator and graph expression system based on YAML configuration, with automated precision validation and performance benchmarking.',
    tags: ['Python', 'C++', 'DNN', 'Framework', 'YAML', 'PyTorch'],
    highlights: [
      'Self-defined operator/graph DSL in YAML, compiled to executable kernels',
      'Automated precision validation against reference implementations',
      'Integrated performance benchmarking pipeline',
      'Software copyright registered',
    ],
  },
  {
    title: 'CNN Library for AI Inference',
    period: '2017.07 – 2020.12',
    description:
      'High-performance convolutional neural network library for heterogeneous AI inference platforms at Hikvision. Optimized key operations across CPU, DSP, and NPU, supporting production surveillance AI workloads.',
    tags: ['C++', 'CNN', 'DSP', 'NPU', 'Computer Vision'],
    highlights: [
      'Optimized convolution, pooling, and activation operators for custom hardware',
      'Cross-platform performance tuning for CPU, DSP, and NPU execution paths',
      'End-to-end delivery: requirements → architecture → optimization → deployment',
    ],
  },
  {
    title: 'IEEE 802.11ax Research',
    period: '2014.09 – 2017.01',
    description:
      'Graduate research on next-generation WiFi (802.11ax/Wi-Fi 6) at National Taiwan University. Focused on UL OFDMA random access and energy-saving mechanisms, resulting in 2 IEEE publications.',
    tags: ['WiFi 6', '802.11ax', 'OFDMA', 'Research', 'C Simulation'],
    highlights: [
      'Published in IEEE Access (2018): Energy saving mechanisms for 802.11ax',
      'Published at IEEE GLOBECOM 2017: UL OFDMA random access performance analysis',
      'Implemented simulation models in C for protocol performance evaluation',
    ],
  },
];
---

<BaseLayout
  title="Projects — Frank Young"
  description="Technical projects by Frank Young in high-performance computing, AI acceleration, and systems engineering."
>
  <Nav />

  <main class="container">
    <section class="page-header">
      <h1>Projects</h1>
      <p class="subtitle">
        A record of technical work spanning GPU kernel optimization, AI infrastructure, and systems research.
      </p>
    </section>

    <div class="projects-list">
      {projects.map((project) => (
        <ProjectCard
          title={project.title}
          period={project.period}
          description={project.description}
          tags={project.tags}
          highlights={project.highlights}
        />
      ))}
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  main {
    padding-top: 3rem;
    padding-bottom: 4rem;
  }

  .page-header {
    margin-bottom: 2.5rem;
  }

  h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    color: var(--text-secondary);
    font-size: 1rem;
    max-width: 560px;
    margin: 0;
  }

  .projects-list {
    display: grid;
    gap: 1.25rem;
  }
</style>
